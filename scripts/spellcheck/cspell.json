{
  "version": "0.2",
  "language": "en-GB",
  "root": "../..",
  "allowCompoundWords": true,
  "ignorePaths": [
    "site/**",
    ".venv/**",
    ".cache/**",
    "node_modules/**",
    "docs/objects.inv",
    "docs/search.json",
    "docs/sitemap.xml"
  ],
  "files": [
    "docs/**/*.md",
    "files/**/*.md"
  ],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./cspell-words.txt",
      "addWords": true
    }
  ]
  ,
  "dictionaries": [
    "project-words"
  ]
}